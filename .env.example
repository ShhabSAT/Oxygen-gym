# Firebase web config — values provided by you (the Firebase project owner).
# Vite ONLY exposes variables prefixed with VITE_ to the client bundle.
# Edit this file to rotate credentials. NEVER commit real secrets to git
# (this file is gitignored).
VITE_FIREBASE_API_KEY=REPLACE_WITH_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=REPLACE_WITH_PROJECT_ID.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=REPLACE_WITH_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=REPLACE_WITH_PROJECT_ID.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=REPLACE_WITH_SENDER_ID
VITE_FIREBASE_APP_ID=REPLACE_WITH_APP_ID
